# Ignore everything by default
*

# Keep the ignore file itself
!.gitignore

# Keep only allowed top-level artifacts
!README.md
!readme.md
!.env.example

# Keep only allowed source trees
!src/
!src/**
!tests/
!tests/**
!venv/
!venv/**
!notebooks/
!notebooks/**

# Never track real env files
.env
.env.*
finetuning.log
notebooks/finetuning.log
!.env.example

# Never track caches or compiled artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
dist/
build/
*.egg-info/
*.log
*.tmp
*.swp

# IDE and OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
