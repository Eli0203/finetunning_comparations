# =============================================================================
# .env.example — Template for all settings required by src/settings/settings.py
# =============================================================================
# HOW TO USE:
#   1. Copy this file to .env  →  cp .env.example .env
#   2. Replace YOUR_HF_TOKEN_HERE with your actual Hugging Face token
#      (get one at https://huggingface.co/settings/tokens)
#   3. The .env file is git-ignored (secrets never leave your machine)
# =============================================================================

# ── Hugging Face Authentication (REQUIRED) ───────────────────────────────────
# Must be a token with at least READ access.
# Field: hf_token   Validator: HF_TOKEN
HF_TOKEN=YOUR_HF_TOKEN_HERE

# ── Model & Task ─────────────────────────────────────────────────────────────
# Field: model_id   Default: bert-base-uncased
MODEL_ID=bert-base-uncased

# Field: task_name  Default: mrpc
# Supported by GLUEDataLoader: mrpc | sst2 | qnli
TASK_NAME=mrpc

# Field: task_type  Default: SEQ_CLS
# PEFT TaskType enum value — must match the model head
TASK_TYPE=SEQ_CLS

# Field: max_seq_length  Default: 512
MAX_SEQ_LENGTH=128

# Field: output_dir  Default: ./output
OUTPUT_DIR=./output

# ── Training Hyperparameters ──────────────────────────────────────────────────
# Field: learning_rate  Default: 2e-5
LEARNING_RATE=2e-5

# Field: batch_size  Default: 16
BATCH_SIZE=16

# Field: epochs  Default: 3
EPOCHS=3

# ── LoRA Adapter Configuration ────────────────────────────────────────────────
# Field: execute_lora  Default: true
EXECUTE_LORA=true

# Field: lora_rank  Default: 8
# Decomposition rank r — higher = more capacity, more parameters
LORA_RANK=8

# Field: lora_alpha  Default: 16
# Scaling factor α — effective multiplier = α / r
LORA_ALPHA=16

# Field: lora_dropout  Default: 0.1
LORA_DROPOUT=0.1

# ── Laplace Extension ────────────────────────────────────────────────────────
# Field: execute_laplace  Default: false
# Set to true to activate LaplaceLoRAEngine post-MAP curvature accumulation
EXECUTE_LAPLACE=false

# ── Causal Engine Configuration ───────────────────────────────────────────────
# Field: execute_causal_engine  Default: false
# Set to true to route training through CausalTrainingOrchestrator
EXECUTE_CAUSAL_ENGINE=false

# ── QLoRA Extension ──────────────────────────────────────────────────────────
# Field: execute_qlora  Default: false
EXECUTE_QLORA=false

# Field: qlora_rank  Default: 4
QLORA_RANK=4

# Field: qlora_alpha  Default: 8
QLORA_ALPHA=8

# Field: qlora_dropout  Default: 0.1
QLORA_DROPOUT=0.1

# ── Training & Logging Strategies ────────────────────────────────────────────
# Field: eval_strategy  Default: epoch
EVAL_STRATEGY=epoch

# Field: save_strategy  Default: epoch
SAVE_STRATEGY=epoch

# Field: save_total_limit  Default: 2
SAVE_TOTAL_LIMIT=2

# Field: logging_strategy  Default: epoch
LOGGING_STRATEGY=epoch

# Field: logging_dir  Default: ./logs
LOGGING_DIR=./logs

# ── Execution Flags ───────────────────────────────────────────────────────────
# Field: use_mock_data  Default: false
# Set to true to skip HF download and use MockDataLoader (unit tests only)
USE_MOCK_DATA=false
