    "# ============================================================\n",
    "# CELL 3: ENVIRONMENT DETECTION - Colab vs. Local Git Clone\n",
    "# ============================================================\n",
    "# Adds a persistent artifact root so checkpoints/results survive runtime resets.\n",
    "# ============================================================\n",
    "import os\n",
    "import subprocess\n",
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "\n",
    "def detect_environment() -> dict:\n",
    "    \"\"\"Detect runtime and resolve persistent artifact paths.\"\"\"\n",
    "    try:\n",
    "        is_colab = \"google.colab\" in str(get_ipython())\n",
    "    except NameError:\n",
    "        is_colab = False\n",
    "\n",
    "    drive_ready = False\n",
    "    drive_root = \"/content/drive/MyDrive/finetuning_persistent\"\n",
    "\n",
    "    if is_colab:\n",
    "        repo_url = os.environ.get(\n",
    "            \"FINETUNNING_REPO_URL\",\n",
    "            \"https://github.com/Eli0203/finetunning_comparations.git\",\n",
    "        )\n",
    "        colab_root = \"/content\"\n",
    "        repo_dir = os.path.join(colab_root, \"finetunning_comparations\")\n",
    "\n",
    "        if not os.path.exists(repo_dir):\n",
    "            print(f\"Cloning repo into {repo_dir} ...\")\n",
    "            subprocess.check_call([\"git\", \"clone\", repo_url, repo_dir])\n",
    "        else:\n",
    "            print(f\"Reusing existing repo at {repo_dir}\")\n",
    "\n",
    "        try:\n",
    "            from google.colab import drive\n",
    "            drive.mount(\"/content/drive\", force_remount=False)\n",
    "            drive_ready = True\n",
    "            print(\"Google Drive mounted at /content/drive\")\n",
    "        except Exception as exc:\n",
    "            print(f\"Drive mount skipped: {exc}\")\n",
    "\n",
    "        os.chdir(repo_dir)\n",
    "        persistent_root = drive_root if drive_ready else os.path.join(repo_dir, \"persistent\")\n",
    "        env_config = {\n",
    "            \"is_colab\": True,\n",
    "            \"base_dir\": repo_dir,\n",
    "            \"src_dir\": os.path.join(repo_dir, \"src\"),\n",
    "            \"persistent_root\": persistent_root,\n",
    "            \"output_dir\": os.path.join(persistent_root, \"output\"),\n",
    "            \"logs_dir\": os.path.join(persistent_root, \"logs\"),\n",
    "            \"state_dir\": os.path.join(persistent_root, \"state\"),\n",
    "            \"drive_ready\": drive_ready,\n",
    "            \"env_file\": os.path.join(repo_dir, \".env\"),\n",
    "        }\n",
    "    else:\n",
    "        def find_git_root(start: str) -> str:\n",
    "            cur = os.path.abspath(start)\n",
    "            for _ in range(12):\n",
    "                if os.path.exists(os.path.join(cur, \".git\")):\n",
    "                    return cur\n",
    "                parent = os.path.dirname(cur)\n",
    "                if parent == cur:\n",
    "                    break\n",
    "                cur = parent\n",
    "            return os.path.abspath(start)\n",
    "\n",
    "        base_dir = find_git_root(os.getcwd())\n",
    "        persistent_root = os.path.join(base_dir, \"persistent\")\n",
    "        env_config = {\n",
    "            \"is_colab\": False,\n",
    "            \"base_dir\": base_dir,\n",
    "            \"src_dir\": os.path.join(base_dir, \"src\"),\n",
    "            \"persistent_root\": persistent_root,\n",
    "            \"output_dir\": os.path.join(persistent_root, \"output\"),\n",
    "            \"logs_dir\": os.path.join(persistent_root, \"logs\"),\n",
    "            \"state_dir\": os.path.join(persistent_root, \"state\"),\n",
    "            \"drive_ready\": False,\n",
    "            \"env_file\": os.path.join(base_dir, \".env\"),\n",
    "        }\n",
    "\n",
    "    for path in [env_config[\"base_dir\"], env_config[\"src_dir\"]]:\n",
    "        if path not in sys.path:\n",
    "            sys.path.insert(0, path)\n",
    "\n",
    "    for key in [\"persistent_root\", \"output_dir\", \"logs_dir\", \"state_dir\"]:\n",
    "        Path(env_config[key]).mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    env_label = \"Google Colab\" if env_config[\"is_colab\"] else \"Local Git Clone\"\n",
    "    print(f\"Environment    : {env_label}\")\n",
    "    print(f\"base_dir       : {env_config['base_dir']}\")\n",
    "    print(f\"persistent_root: {env_config['persistent_root']}\")\n",
    "    print(f\"output_dir     : {env_config['output_dir']}\")\n",
    "    print(f\"logs_dir       : {env_config['logs_dir']}\")\n",
    "    print(f\"state_dir      : {env_config['state_dir']}\")\n",
    "    if env_config[\"is_colab\"]:\n",
    "        print(f\"drive_mounted  : {env_config['drive_ready']}\")\n",
    "    return env_config\n",
    "\n",
    "\n",
    "ENV = detect_environment()"
   ]
