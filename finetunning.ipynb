    "if _is_colab_runtime():\n",
    "    subprocess.check_call(\n",
    "        [sys.executable, \"-m\", \"pip\", \"install\", \"--quiet\", \"uv>=0.8.15\"]\n",
    "    )\n",
    "    print(\"✅  Colab bootstrap packages installed (`uv` available).\")\n",
