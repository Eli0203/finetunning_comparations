   "source": [
    "---\n",
    "## Method 2 - Laplace-LoRA\n",
    "\n",
    "**Two-phase pipeline:**\n",
    "1. **Phase 1 (MAP)**: Train LoRA identically to baseline -> $\\theta_{\\text{MAP}}$\n",
    "2. **Phase 2 (Posterior)**: Estimate Hessian via K-FAC (Kronecker-factored approximate curvature), wrap Gaussian posterior around $\\theta_{\\text{MAP}}$\n",
    "\n",
    "**Result**: Same accuracy as baseline; **lower ECE/NLL** - predictions are calibrated via Bayesian smoothing.\n",
    "\n",
    "**Failure policy**: if the Laplace posterior phase fails, or if curvature factors are not actually accumulated, the notebook aborts the Laplace-LoRA run. Fallback to MAP or baseline-style evaluation is disabled.\n",
    "\n",
    "K-FAC factors are maintained low-rank via incremental SVD, avoiding $O(P^2)$ memory cost."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7a82ef6b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 15: LAPLACE-LORA - Training Function (resume-capable)\n",
    "# ============================================================\n",
    "\n",
    "\n",
    "def train_laplace_lora(cfg: LoRAExperimentConfig, device: str) -> dict:\n",
    "    method = \"Laplace-LoRA\"\n",
    "    print(f\"\\n{'=' * 60}\")\n",
    "    print(f\"[{method}] Task: {cfg.task_name.upper()}\")\n",
    "    print(f\"{'=' * 60}\")\n",
    "\n",
    "    run_dir = str(Path(cfg.output_dir) / f\"laplace_lora_{cfg.task_name}\")\n",
    "    Path(run_dir).mkdir(parents=True, exist_ok=True)\n",
    "    ckpt = latest_checkpoint(run_dir) if should_resume(cfg) else None\n",
    "    mark_experiment_status(method, cfg.task_name, \"running\", run_dir, checkpoint=ckpt)\n",
    "\n",
    "    loader, train_ds, eval_ds, _ = load_glue_runtime(cfg)\n",
    "    num_labels = GLUE_TASK_REGISTRY[cfg.task_name][\"num_labels\"]\n",
    "\n",
    "    base_model = AutoModelForSequenceClassification.from_pretrained(\n",
    "        cfg.model_id,\n",
    "        num_labels=num_labels,\n",
    "    )\n",
    "    engine = FineTuningEngine(\n",
    "        task_type=TaskType.SEQ_CLS,\n",
    "        model=base_model,\n",
    "        rank=cfg.rank,\n",
    "        alpha=cfg.alpha,\n",
    "        dropout=cfg.dropout,\n",
    "    )\n",
    "    model = engine.apply_lora()\n",
    "    model.to(device)\n",
    "\n",
    "    evaluator = UnifiedEvaluator(cfg.task_name)\n",
    "    use_fp16, use_bf16 = resolve_precision_flags(device)\n",
    "    training_args = build_training_args(\n",
    "        cfg=cfg,\n",
    "        run_dir=run_dir,\n",
    "        metric_name=f\"eval_{GLUE_TASK_REGISTRY[cfg.task_name]['metric']}\",\n",
    "        greater_is_better=True,\n",
    "        use_fp16=use_fp16,\n",
    "        use_bf16=use_bf16,\n",
    "        max_steps=cfg.max_steps,\n",
    "        gradient_checkpointing=(device == \"cuda\"),\n",
    "    )\n",
    "\n",
    "    trainer = Trainer(\n",
    "        model=model,\n",
    "        args=training_args,\n",
    "        train_dataset=train_ds,\n",
    "        eval_dataset=eval_ds,\n",
    "        compute_metrics=make_compute_metrics(evaluator),\n",
    "    )\n",
    "\n",
    "    t_start = time.time()\n",
    "    try:\n",
    "        trainer.train(resume_from_checkpoint=ckpt)\n",
    "        print(\"Phase 1 (MAP training) complete.\")\n",
    "\n",
    "        laplace_engine = LaplaceLoRAEngine(\n",
    "            lora_engine=engine,\n",
    "            prior_precision=1.0,\n",
    "            nkfac=10,\n",
    "        )\n",
    "\n",
    "        curvature_loader = loader.get_loader(\"train\", batch_size=cfg.batch_size)\n",
    "        laplace_engine.accumulate_curvature(curvature_loader)\n",
    "\n",
    "        if not laplace_engine.curvature_factors:\n",
    "            raise RuntimeError(\n",
    "                \"Laplace posterior accumulation produced no curvature factors. \"\n",
    "                \"Failing closed by policy.\"\n",
    "            )\n",
    "\n",
    "        has_non_empty_factor = any(\n",
    "            A.numel() > 0 and G.numel() > 0 and A.shape[1] > 0 and G.shape[1] > 0\n",
    "            for A, G in laplace_engine.curvature_factors.values()\n",
    "        )\n",
    "        if not has_non_empty_factor:\n",
    "            raise RuntimeError(\n",
    "                \"Laplace curvature factors are empty after accumulation. \"\n",
    "                \"Failing closed by policy.\"\n",
    "            )\n",
    "\n",
    "        eval_results = trainer.evaluate()\n",
    "        eval_nll = eval_results.get(\"eval_nll\")\n",
    "        if eval_nll is None or not np.isfinite(eval_nll):\n",
    "            raise RuntimeError(\n",
    "                \"Laplace phase requires a finite eval_nll metric to compute evidence.\"\n",
    "            )\n",
    "\n",
    "        log_evidence = laplace_engine.get_marginal_likelihood(-float(eval_nll))\n",
    "        if not np.isfinite(log_evidence):\n",
    "            raise RuntimeError(\"Laplace marginal likelihood is non-finite.\")\n",
    "\n",
    "        print(f\"Phase 2 (Laplace posterior) complete. log p(D) ~= {log_evidence:.4f}\")\n",
    "        latency_ms = measure_inference_latency(model, eval_ds, device)\n",
    "    except Exception as exc:\n",
    "        mark_experiment_status(\n",
    "            method,\n",
    "            cfg.task_name,\n",
    "            \"failed\",\n",
    "            run_dir,\n",
    "            checkpoint=latest_checkpoint(run_dir),\n",
    "            error=str(exc),\n",
    "        )\n",
    "        raise RuntimeError(\n",
    "            \"Laplace-LoRA aborted because Laplace posterior validation failed.\"\n",
    "        ) from exc\n",
    "\n",
    "    train_time_s = time.time() - t_start\n",
    "    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "    best_ckpt = latest_checkpoint(run_dir)\n",
    "    result = {\n",
    "        \"method\": method,\n",
    "        \"task\": cfg.task_name.upper(),\n",
    "        \"accuracy\": eval_results.get(\"eval_accuracy\", float(\"nan\")),\n",
    "        \"f1\": eval_results.get(\"eval_f1\", float(\"nan\")),\n",
    "        \"nll\": eval_results.get(\"eval_nll\", float(\"nan\")),\n",
    "        \"ece\": eval_results.get(\"eval_ece\", float(\"nan\")),\n",
    "        \"latency_ms\": round(latency_ms, 3),\n",
    "        \"train_time_s\": round(train_time_s, 1),\n",
    "        \"trainable_params\": trainable,\n",
    "        \"output_dir\": run_dir,\n",
    "        \"checkpoint\": best_ckpt,\n",
    "    }\n",
    "    mark_experiment_status(\n",
    "        method,\n",
    "        cfg.task_name,\n",
    "        \"completed\",\n",
    "        run_dir,\n",
    "        checkpoint=best_ckpt,\n",
    "        metrics=result,\n",
    "    )\n",
    "    cleanup_memory(f\"{method}-{cfg.task_name}\")\n",
    "    print(f\"Completed: {result}\")\n",
    "    return result"
   ]
  },
