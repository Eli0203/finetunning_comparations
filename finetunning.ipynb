    "# ============================================================\n",
    "# CELL 4: PROJECT INSTALL FROM pyproject.toml\n",
    "# ============================================================\n",
    "# What this cell does:\n",
    "#   1. Parses and prints the project metadata from pyproject.toml\n",
    "#   2. On Colab: installs the project in editable mode from pyproject.toml\n",
    "#      so notebook imports always see the current src/ checkout\n",
    "#   3. On Local: shows the current environment and reminds you to run\n",
    "#      `uv sync` if pyproject.toml changed\n",
    "# ============================================================\n",
    "import os\n",
    "import subprocess\n",
    "import sys\n",
    "\n",
    "try:\n",
    "    import tomllib\n",
    "except ImportError:\n",
    "    import tomli as tomllib\n",
    "\n",
    "\n",
    "_toml_path = os.path.join(ENV[\"base_dir\"], \"pyproject.toml\")\n",
    "with open(_toml_path, \"rb\") as _f:\n",
    "    _pyproject = tomllib.load(_f)\n",
    "\n",
    "_proj = _pyproject.get(\"project\", {})\n",
    "_deps = _proj.get(\"dependencies\", [])\n",
    "_dev_deps = _pyproject.get(\"dependency-groups\", {}).get(\"dev\", [])\n",
    "_py_req = _proj.get(\"requires-python\", \"unspecified\")\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(f\"  PROJECT      : {_proj.get('name')}  v{_proj.get('version')}\")\n",
    "print(f\"  PYTHON       : {_py_req}\")\n",
    "print(f\"  DESCRIPTION  : {_proj.get('description')}\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "print(f\"\\n📦  Runtime dependencies ({len(_deps)} packages):\")\n",
    "for dep in _deps:\n",
    "    print(f\"    {dep}\")\n",
    "\n",
    "print(f\"\\n🛠️   Dev dependencies ({len(_dev_deps)} packages):\")\n",
    "for dep in _dev_deps:\n",
    "    print(f\"    {dep}\")\n",
    "\n",
    "if ENV[\"is_colab\"]:\n",
    "    print(\"\\n🚀  Colab detected — installing the project from pyproject.toml …\")\n",
    "    subprocess.check_call(\n",
    "        [\"uv\", \"pip\", \"install\", \"--system\", \"-e\", \".\"],\n",
    "        cwd=ENV[\"base_dir\"],\n",
    "    )\n",
    "    print(\"✅  Editable install complete — notebook imports now use the live src/ tree.\")\n",
    "else:\n",
    "    print(\"\\n🖥️   Local environment detected — using the existing uv-managed environment.\")\n",
    "    print(\"     Run `uv sync` in a terminal if pyproject.toml changed.\\n\")\n",
    "    _installed = subprocess.run(\n",
    "        [sys.executable, \"-m\", \"pip\", \"list\"],\n",
    "        capture_output=True,\n",
    "        text=True,\n",
    "        cwd=ENV[\"base_dir\"],\n",
    "    )\n",
    "    if _installed.returncode == 0:\n",
    "        _lines = _installed.stdout.strip().splitlines()\n",
    "        print(f\"📋  Installed packages visible to the current kernel ({max(len(_lines) - 2, 0)} packages):\")\n",
    "        for _line in _lines[:32]:\n",
    "            print(f\"    {_line}\")\n",
    "        if len(_lines) > 32:\n",
    "            print(f\"    … and {len(_lines) - 32} more\")\n",
    "    else:\n",
    "        print(\"⚠️   Could not inspect installed packages from the current kernel.\")"
