   "source": [
    "---\n",
    "## Method 3 - Causal Fine-Tuning\n",
    "\n",
    "**Reshapes training signal via do-calculus**: Instead of $\\min_\\theta \\mathbb{E}[\\log p(y|x)]$, minimises the interventional objective $\\min_\\theta \\mathbb{E}[w(x) \\log p(y|x)]$.\n",
    "\n",
    "**Causal weighting** via backdoor adjustment marginalises over confounders, so the model learns features invariant to distribution shifts.\n",
    "\n",
    "**Implementation**: `CausalTrainingOrchestrator` runs a 7-step pipeline:\n",
    "1. Identify causal paths (gradient-based sensitivity)\n",
    "2. Allocate budget (mediation analysis)\n",
    "3. Create double buffer for IPC\n",
    "4. Start async weight sampler\n",
    "5. Create weight applier\n",
    "6. Register trainer callback\n",
    "7. Train with continuous weight application every 10 steps\n",
    "\n",
    "**Failure policy**: if causal gradients cannot be populated, if no causal paths are identified, or if diagnostics show no causal weight publication/application, the notebook aborts the causal run. Baseline fallback is disabled for these failure modes.\n",
    "\n",
    "**Result**: Potentially higher accuracy on spurious-correlation tasks; structural invariance rather than just calibration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "b43e13b9",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "# ============================================================\n",
    "# CELL 18: CAUSAL FINE-TUNING - Training Function (resume-capable)\n",
    "# ============================================================\n",
    "\n",
    "\n",
    "def train_causal_ft(cfg: LoRAExperimentConfig, device: str) -> dict:\n",
    "    from src.finetuner.causal_engine import CausalGradientUnavailableError\n",
    "\n",
    "    method = \"Causal FT\"\n",
    "    print(f\"\\n{'=' * 60}\")\n",
    "    print(f\"[{method}] Task: {cfg.task_name.upper()}\")\n",
    "    print(f\"{'=' * 60}\")\n",
    "\n",
    "    run_dir = str(Path(cfg.output_dir) / f\"causal_{cfg.task_name}\")\n",
    "    Path(run_dir).mkdir(parents=True, exist_ok=True)\n",
    "    ckpt = latest_checkpoint(run_dir) if should_resume(cfg) else None\n",
    "    mark_experiment_status(method, cfg.task_name, \"running\", run_dir, checkpoint=ckpt)\n",
    "\n",
    "    loader, train_ds, eval_ds, _ = load_glue_runtime(cfg)\n",
    "    num_labels = GLUE_TASK_REGISTRY[cfg.task_name][\"num_labels\"]\n",
    "\n",
    "    base_model = AutoModelForSequenceClassification.from_pretrained(\n",
    "        cfg.model_id,\n",
    "        num_labels=num_labels,\n",
    "    )\n",
    "    engine = FineTuningEngine(\n",
    "        task_type=TaskType.SEQ_CLS,\n",
    "        model=base_model,\n",
    "        rank=cfg.rank,\n",
    "        alpha=cfg.alpha,\n",
    "        dropout=cfg.dropout,\n",
    "    )\n",
    "    model = engine.apply_lora()\n",
    "    model.to(device)\n",
    "\n",
    "    evaluator = UnifiedEvaluator(cfg.task_name)\n",
    "    use_fp16, use_bf16 = resolve_precision_flags(device)\n",
    "    training_args = build_training_args(\n",
    "        cfg=cfg,\n",
    "        run_dir=run_dir,\n",
    "        metric_name=f\"eval_{GLUE_TASK_REGISTRY[cfg.task_name]['metric']}\",\n",
    "        greater_is_better=True,\n",
    "        use_fp16=use_fp16,\n",
    "        use_bf16=use_bf16,\n",
    "        max_steps=cfg.max_steps,\n",
    "        gradient_checkpointing=(device == \"cuda\"),\n",
    "    )\n",
    "\n",
    "    trainer = Trainer(\n",
    "        model=model,\n",
    "        args=training_args,\n",
    "        train_dataset=train_ds,\n",
    "        eval_dataset=eval_ds,\n",
    "        compute_metrics=make_compute_metrics(evaluator),\n",
    "    )\n",
    "\n",
    "    causal_engine = CausalMonteCLoRAEngine(\n",
    "        lora_engine=engine,\n",
    "        causal_threshold=0.1,\n",
    "        sample_budget=cfg.total_causal_budget,\n",
    "    )\n",
    "    causal_sampler = CausalWeightSampler(\n",
    "        causal_engine=causal_engine,\n",
    "        model=model,\n",
    "        device=device,\n",
    "    )\n",
    "\n",
    "    # ----------------------------------------------------------------\n",
    "    # Calibrate async_max_steps to the total number of training steps.\n",
    "    # The HF Trainer counts ONE global_step per optimizer update (after\n",
    "    # gradient accumulation).  We use the dataset length to estimate\n",
    "    # the total so the background sampler keeps generating fresh causal\n",
    "    # weights throughout the full training run instead of stalling after\n",
    "    # the small default (100 steps).\n",
    "    # ----------------------------------------------------------------\n",
    "    if cfg.max_steps > 0:\n",
    "        # Explicit step cap takes priority.\n",
    "        total_training_steps = cfg.max_steps\n",
    "    else:\n",
    "        steps_per_epoch = max(1, len(train_ds) // max(1, cfg.batch_size))\n",
    "        # HF Trainer counts optimizer updates, not raw forward passes.\n",
    "        optimizer_steps_per_epoch = max(\n",
    "            1,\n",
    "            steps_per_epoch // max(1, cfg.gradient_accumulation_steps),\n",
    "        )\n",
    "        total_training_steps = optimizer_steps_per_epoch * cfg.epochs\n",
    "\n",
    "    # Keep at least the user-configured budget; expand to cover full run.\n",
    "    effective_async_max_steps = max(cfg.async_max_steps, total_training_steps)\n",
    "    print(\n",
    "        f\"[Causal FT] total_training_steps={total_training_steps}, \"\n",
    "        f\"async_max_steps={effective_async_max_steps} \"\n",
    "        f\"(cfg.async_max_steps={cfg.async_max_steps})\"\n",
    "    )\n",
    "\n",
    "    causal_config = CausalTrainingConfig(\n",
    "        total_causal_budget=cfg.total_causal_budget,\n",
    "        async_max_steps=effective_async_max_steps,\n",
    "        apply_interval=cfg.apply_interval,\n",
    "        device=device,\n",
    "        enable_warmup=False,\n",
    "        warmup_steps=10,\n",
    "        seed=SEED,\n",
    "    )\n",
    "\n",
    "    orchestrator = CausalTrainingOrchestrator(\n",
    "        lora_engine=engine,\n",
    "        causal_engine=causal_engine,\n",
    "        trainer=trainer,\n",
    "        causal_sampler=causal_sampler,\n",
    "        config=causal_config,\n",
    "    )\n",
    "\n",
    "    train_loader = loader.get_loader(\"train\", batch_size=cfg.batch_size)\n",
    "    t_start = time.time()\n",
    "\n",
    "    try:\n",
    "        orchestrator.prepare(model, train_loader)\n",
    "\n",
    "        # Inject resume checkpoint into orchestrator.run_training() via trainer hook.\n",
    "        original_train = trainer.train\n",
    "        trainer.train = lambda resume_from_checkpoint=None: original_train(\n",
    "            resume_from_checkpoint=ckpt\n",
    "        )\n",
    "\n",
    "        orchestrator.run_training()\n",
    "        diagnostics = orchestrator.get_diagnostics()\n",
    "        logger.info(f\"Causal training diagnostics: {diagnostics}\")\n",
    "\n",
    "        if diagnostics.get(\"state\") != orchestrator.COMPLETED:\n",
    "            raise RuntimeError(\n",
    "                f\"Orchestrator did not complete successfully: {diagnostics.get('state')}\"\n",
    "            )\n",
    "\n",
    "        causal_summary = diagnostics.get(\"causal_summary\") or {}\n",
    "        causal_paths = causal_summary.get(\"causal_paths\") or []\n",
    "        if len(causal_paths) == 0:\n",
    "            raise RuntimeError(\"No causal paths were identified.\")\n",
    "\n",
    "        sampler_status = diagnostics.get(\"async_sampler_status\") or {}\n",
    "        sampler_metrics = sampler_status.get(\"metrics\") or {}\n",
    "        published_batches = int(sampler_metrics.get(\"published_batches\", 0))\n",
    "        if published_batches <= 0:\n",
    "            raise RuntimeError(\"Causal sampler published zero batches.\")\n",
    "\n",
    "        sampler_exitcode = sampler_status.get(\"exitcode\")\n",
    "        if sampler_exitcode not in (None, 0):\n",
    "            raise RuntimeError(f\"Background sampler exited with non-zero code: {sampler_exitcode}\")\n",
    "\n",
    "        if sampler_status.get(\"last_error\"):\n",
    "            raise RuntimeError(\n",
    "                f\"Background sampler reported error: {sampler_status.get('last_error')}\"\n",
    "            )\n",
    "\n",
    "        weight_metrics = diagnostics.get(\"weight_application_metrics\") or {}\n",
    "        times_applied = int(weight_metrics.get(\"times_applied\", 0))\n",
    "        if times_applied <= 0:\n",
    "            raise RuntimeError(\"No causal weights were applied during training.\")\n",
    "\n",
    "        callback_metrics = diagnostics.get(\"callback_metrics\") or {}\n",
    "        applied_steps = int(callback_metrics.get(\"applied_steps\", 0))\n",
    "        if applied_steps <= 0:\n",
    "            raise RuntimeError(\"Callback reports zero applied steps.\")\n",
    "\n",
    "        callback_failures = int(callback_metrics.get(\"application_failures\", 0))\n",
    "        if callback_failures > 0:\n",
    "            raise RuntimeError(\n",
    "                f\"Callback reported {callback_failures} application failures.\"\n",
    "            )\n",
    "\n",
    "        eval_results = trainer.evaluate()\n",
    "        latency_ms = measure_inference_latency(model, eval_ds, device)\n",
    "    except CausalGradientUnavailableError as exc:\n",
    "        mark_experiment_status(\n",
    "            method,\n",
    "            cfg.task_name,\n",
    "            \"failed\",\n",
    "            run_dir,\n",
    "            checkpoint=latest_checkpoint(run_dir),\n",
    "            error=str(exc),\n",
    "        )\n",
    "        raise RuntimeError(\n",
    "            \"Causal FT aborted because gradients could not be obtained.\"\n",
    "        ) from exc\n",
    "    except Exception as exc:\n",
    "        mark_experiment_status(\n",
    "            method,\n",
    "            cfg.task_name,\n",
    "            \"failed\",\n",
    "            run_dir,\n",
    "            checkpoint=latest_checkpoint(run_dir),\n",
    "            error=str(exc),\n",
    "        )\n",
    "        raise RuntimeError(\n",
    "            \"Causal FT aborted because diagnostics validation failed.\"\n",
    "        ) from exc\n",
    "\n",
    "    train_time_s = time.time() - t_start\n",
    "    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "    best_ckpt = latest_checkpoint(run_dir)\n",
    "    result = {\n",
    "        \"method\": method,\n",
    "        \"task\": cfg.task_name.upper(),\n",
    "        \"accuracy\": eval_results.get(\"eval_accuracy\", float(\"nan\")),\n",
    "        \"f1\": eval_results.get(\"eval_f1\", float(\"nan\")),\n",
    "        \"nll\": eval_results.get(\"eval_nll\", float(\"nan\")),\n",
    "        \"ece\": eval_results.get(\"eval_ece\", float(\"nan\")),\n",
    "        \"latency_ms\": round(latency_ms, 3),\n",
    "        \"train_time_s\": round(train_time_s, 1),\n",
    "        \"trainable_params\": trainable,\n",
    "        \"output_dir\": run_dir,\n",
    "        \"checkpoint\": best_ckpt,\n",
    "    }\n",
    "    mark_experiment_status(\n",
    "        method,\n",
    "        cfg.task_name,\n",
    "        \"completed\",\n",
    "        run_dir,\n",
    "        checkpoint=best_ckpt,\n",
    "        metrics=result,\n",
    "    )\n",
    "    cleanup_memory(f\"{method}-{cfg.task_name}\")\n",
    "    print(f\"Completed: {result}\")\n",
    "    return result\n"
   ]
  },
