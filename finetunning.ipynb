   "source": [
    "# ============================================================\n",
    "# CELL 10: RECOVERY + EVALUATION UTILITIES\n",
    "# ============================================================\n",
    "import inspect\n",
    "import platform\n",
    "\n",
    "RUNTIME_STATE_PATH = Path(ENV[\"state_dir\"]) / \"runtime_state.json\"\n",
    "RESULTS_SNAPSHOT_PATH = Path(ENV[\"state_dir\"]) / \"results_snapshot.json\"\n",
    "IS_WINDOWS = platform.system().lower().startswith(\"win\")\n",
    "\n",
    "\n",
    "def utc_now() -> str:\n",
    "    return datetime.now(timezone.utc).isoformat()\n",
    "\n",
    "\n",
    "def load_runtime_state() -> dict:\n",
    "    if RUNTIME_STATE_PATH.exists():\n",
    "        return json.loads(RUNTIME_STATE_PATH.read_text(encoding=\"utf-8\"))\n",
    "    return {\"created_at\": utc_now(), \"experiments\": {}}\n",
    "\n",
    "\n",
    "def save_runtime_state(state: dict) -> None:\n",
    "    state[\"updated_at\"] = utc_now()\n",
    "    RUNTIME_STATE_PATH.write_text(json.dumps(state, indent=2), encoding=\"utf-8\")\n",
    "\n",
    "\n",
    "def snapshot_results(results: List[dict]) -> None:\n",
    "    payload = {\"saved_at\": utc_now(), \"results\": results}\n",
    "    RESULTS_SNAPSHOT_PATH.write_text(json.dumps(payload, indent=2), encoding=\"utf-8\")\n",
    "\n",
    "\n",
    "RUNTIME_STATE = load_runtime_state()\n",
    "\n",
    "\n",
    "def experiment_key(method: str, task_name: str) -> str:\n",
    "    return f\"{method.lower().replace(' ', '_')}::{task_name.lower()}\"\n",
    "\n",
    "\n",
    "def mark_experiment_status(\n",
    "    method: str,\n",
    "    task_name: str,\n",
    "    status: str,\n",
    "    output_dir: str,\n",
    "    checkpoint: Optional[str] = None,\n",
    "    metrics: Optional[dict] = None,\n",
    "    error: Optional[str] = None,\n",
    ") -> None:\n",
    "    key = experiment_key(method, task_name)\n",
    "    payload = {\n",
    "        \"status\": status,\n",
    "        \"updated_at\": utc_now(),\n",
    "        \"output_dir\": output_dir,\n",
    "        \"checkpoint\": checkpoint,\n",
    "        \"metrics\": metrics or {},\n",
    "        \"error\": error,\n",
    "    }\n",
    "    RUNTIME_STATE.setdefault(\"experiments\", {})[key] = payload\n",
    "    save_runtime_state(RUNTIME_STATE)\n",
    "\n",
    "\n",
    "def is_completed(method: str, task_name: str) -> bool:\n",
    "    key = experiment_key(method, task_name)\n",
    "    entry = RUNTIME_STATE.get(\"experiments\", {}).get(key, {})\n",
    "    return entry.get(\"status\") == \"completed\"\n",
    "\n",
    "\n",
    "def latest_checkpoint(path: str) -> Optional[str]:\n",
    "    root = Path(path)\n",
    "    if not root.exists():\n",
    "        return None\n",
    "    checkpoints = sorted(root.glob(\"checkpoint-*\"), key=lambda p: p.stat().st_mtime)\n",
    "    if not checkpoints:\n",
    "        return None\n",
    "    return str(checkpoints[-1])\n",
    "\n",
    "\n",
    "def should_resume(cfg: LoRAExperimentConfig) -> bool:\n",
    "    return cfg.resume_policy.lower() in {\"latest\", \"auto\", \"true\", \"1\"}\n",
    "\n",
    "\n",
    "def cleanup_memory(phase: str) -> None:\n",
    "    gc.collect()\n",
    "    if torch.cuda.is_available():\n",
    "        torch.cuda.empty_cache()\n",
    "    MemoryOptimizer.log_resource_usage(phase)\n",
    "\n",
    "\n",
    "def _supports_training_arg(name: str) -> bool:\n",
    "    \"\"\"Check if current transformers.TrainingArguments supports a kwarg.\"\"\"\n",
    "    return name in inspect.signature(TrainingArguments.__init__).parameters\n",
    "\n",
    "\n",
    "def _set_if_supported(kwargs: dict, key: str, value) -> None:\n",
    "    if _supports_training_arg(key):\n",
    "        kwargs[key] = value\n",
    "\n",
    "\n",
    "def resolve_precision_flags(device: str) -> tuple[bool, bool]:\n",
    "    \"\"\"Return (use_fp16, use_bf16) for the current runtime safely.\"\"\"\n",
    "    if device != \"cuda\" or not torch.cuda.is_available():\n",
    "        return False, False\n",
    "\n",
    "    bf16_supported = bool(\n",
    "        hasattr(torch.cuda, \"is_bf16_supported\") and torch.cuda.is_bf16_supported()\n",
    "    )\n",
    "    if bf16_supported:\n",
    "        return False, True\n",
    "    return True, False\n",
    "\n",
    "\n",
    "def default_dataloader_workers() -> int:\n",
    "    \"\"\"\n",
    "    Cross-platform worker policy:\n",
    "    - Windows: 0 to avoid spawn-related DataLoader instability in notebooks.\n",
    "    - Linux/macOS + CUDA: small parallelism.\n",
    "    - CPU-only: 0 for maximal compatibility.\n",
    "    \"\"\"\n",
    "    if IS_WINDOWS:\n",
    "        return 0\n",
    "    return 2 if torch.cuda.is_available() else 0\n",
    "\n",
    "\n",
    "def build_training_args(\n",
    "    cfg: LoRAExperimentConfig,\n",
    "    run_dir: str,\n",
    "    metric_name: str,\n",
    "    greater_is_better: bool,\n",
    "    use_fp16: bool,\n",
    "    use_bf16: bool,\n",
    "    max_steps: int = -1,\n",
    "    dataloader_workers: Optional[int] = None,\n",
    "    gradient_checkpointing: bool = True,\n",
    "    lr_scheduler_type: str = \"linear\",\n",
    ") -> TrainingArguments:\n",
    "    if dataloader_workers is None:\n",
    "        dataloader_workers = default_dataloader_workers()\n",
    "\n",
    "    kwargs = {\n",
    "        \"output_dir\": run_dir,\n",
    "        \"num_train_epochs\": cfg.epochs,\n",
    "        \"max_steps\": max_steps,\n",
    "        \"per_device_train_batch_size\": cfg.batch_size,\n",
    "        \"per_device_eval_batch_size\": cfg.batch_size,\n",
    "        \"gradient_accumulation_steps\": cfg.gradient_accumulation_steps,\n",
    "        \"learning_rate\": cfg.learning_rate,\n",
    "        \"save_strategy\": \"steps\",\n",
    "        \"save_steps\": cfg.save_steps,\n",
    "        \"save_total_limit\": 3,\n",
    "        \"logging_strategy\": \"steps\",\n",
    "        \"logging_steps\": cfg.logging_steps,\n",
    "        \"load_best_model_at_end\": True,\n",
    "        \"metric_for_best_model\": metric_name,\n",
    "        \"greater_is_better\": greater_is_better,\n",
    "        \"remove_unused_columns\": False,\n",
    "        \"dataloader_num_workers\": dataloader_workers,\n",
    "        \"dataloader_pin_memory\": torch.cuda.is_available() and not IS_WINDOWS,\n",
    "        \"gradient_checkpointing\": bool(gradient_checkpointing and (DEVICE == \"cuda\")),\n",
    "        \"report_to\": \"none\",\n",
    "    }\n",
    "\n",
    "    # transformers version compatibility (v4 uses evaluation_strategy; v5 uses eval_strategy).\n",
    "    if _supports_training_arg(\"eval_strategy\"):\n",
    "        kwargs[\"eval_strategy\"] = \"steps\"\n",
    "    elif _supports_training_arg(\"evaluation_strategy\"):\n",
    "        kwargs[\"evaluation_strategy\"] = \"steps\"\n",
    "\n",
    "    _set_if_supported(kwargs, \"eval_steps\", cfg.eval_steps)\n",
    "    _set_if_supported(kwargs, \"fp16\", use_fp16)\n",
    "    _set_if_supported(kwargs, \"bf16\", use_bf16)\n",
    "    _set_if_supported(kwargs, \"lr_scheduler_type\", lr_scheduler_type)\n",
    "    _set_if_supported(kwargs, \"save_safetensors\", True)\n",
    "    _set_if_supported(kwargs, \"dataloader_persistent_workers\", dataloader_workers > 0)\n",
    "\n",
    "    return TrainingArguments(**kwargs)\n",
    "\n",
    "\n",
    "def measure_inference_latency(model, eval_ds, device: str, n_samples: int = 100) -> float:\n",
    "    model.eval()\n",
    "    subset = eval_ds.select(range(min(n_samples, len(eval_ds))))\n",
    "    keys = [k for k in [\"input_ids\", \"attention_mask\", \"token_type_ids\"] if k in subset.features]\n",
    "\n",
    "    with torch.no_grad():\n",
    "        warmup_batch = {k: subset[k][:4].to(device) for k in keys}\n",
    "        _ = model(**warmup_batch)\n",
    "\n",
    "    latencies = []\n",
    "    with torch.no_grad():\n",
    "        for i in range(len(subset)):\n",
    "            single = {k: subset[k][i].unsqueeze(0).to(device) for k in keys}\n",
    "            if device == \"cuda\":\n",
    "                torch.cuda.synchronize()\n",
    "            t0 = time.perf_counter()\n",
    "            _ = model(**single)\n",
    "            if device == \"cuda\":\n",
    "                torch.cuda.synchronize()\n",
    "            latencies.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "    return float(np.mean(latencies))\n",
    "\n",
    "\n",
    "def make_compute_metrics(evaluator: UnifiedEvaluator):\n",
    "    def compute_metrics(eval_pred):\n",
    "        logits_np, labels_np = eval_pred\n",
    "        logits_t = torch.tensor(logits_np, dtype=torch.float32)\n",
    "        labels_t = torch.tensor(labels_np, dtype=torch.long)\n",
    "        return evaluator.compute_all(logits_t, labels_t)\n",
    "\n",
    "    return compute_metrics\n",
    "\n",
    "\n",
    "print(\"Recovery and evaluation utilities ready.\")\n",
    "print(f\"Runtime state file : {RUNTIME_STATE_PATH}\")\n",
    "print(f\"Results snapshot   : {RESULTS_SNAPSHOT_PATH}\")\n",
    "print(f\"Platform           : {'Windows' if IS_WINDOWS else 'Non-Windows'}\")\n",
    "print(f\"Device             : {DEVICE}\")\n",
    "print(f\"DataLoader workers : {default_dataloader_workers()}\")"
   ]
  },
