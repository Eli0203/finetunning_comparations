    "# CELL 11: EXECUTABLE CHECKLIST (Plan -> Enforced Tasks)\n",
    "# ============================================================\n",
    "import shutil\n",
    "\n",
    "CHECKLIST_REGISTRY: List[dict] = []\n",
    "\n",
    "\n",
    "def checklist_mark(item: str, status: str, details: str = \"\") -> None:\n",
    "    \"\"\"Track checklist item status for audit and reproducibility.\"\"\"\n",
    "    if status not in {\"passed\", \"failed\", \"skipped\"}:\n",
    "        raise ValueError(f\"Invalid checklist status: {status}\")\n",
    "    CHECKLIST_REGISTRY.append(\n",
    "        {\n",
    "            \"time\": utc_now(),\n",
    "            \"item\": item,\n",
    "            \"status\": status,\n",
    "            \"details\": details,\n",
    "        }\n",
    "    )\n",
    "\n",
    "\n",
    "def checklist_require(condition: bool, item: str, fail_message: str) -> None:\n",
    "    \"\"\"Record and enforce a fail-closed precondition.\"\"\"\n",
    "    if condition:\n",
    "        checklist_mark(item, \"passed\")\n",
    "    else:\n",
    "        checklist_mark(item, \"failed\", fail_message)\n",
    "        raise RuntimeError(f\"Checklist gate failed: {item} | {fail_message}\")\n",
    "\n",
    "\n",
    "def run_preflight_checklist(configs: List[LoRAExperimentConfig], device: str) -> None:\n",
    "    \"\"\"Validate plan assumptions before any experiment starts.\"\"\"\n",
    "    uv_available = shutil.which(\"uv\") is not None\n",
    "    checklist_require(\n",
    "        uv_available,\n",
    "        \"preflight.uv_available\",\n",
    "        \"`uv` command was not found in PATH.\",\n",
    "    )\n",
    "\n",
    "    supported = {\"mrpc\", \"sst2\", \"qnli\"}\n",
    "    for cfg in configs:\n",
    "        checklist_require(\n",
    "            cfg.task_name in supported,\n",
    "            f\"preflight.task_supported.{cfg.task_name}\",\n",
    "            f\"Unsupported task: {cfg.task_name}\",\n",
    "        )\n",
    "        checklist_require(\n",
    "            cfg.total_causal_budget > 0,\n",
    "            f\"preflight.causal_budget_positive.{cfg.task_name}\",\n",
    "            f\"total_causal_budget must be > 0, got {cfg.total_causal_budget}\",\n",
    "        )\n",
    "        checklist_require(\n",
    "            cfg.async_max_steps > 0,\n",
    "            f\"preflight.async_steps_positive.{cfg.task_name}\",\n",
    "            f\"async_max_steps must be > 0, got {cfg.async_max_steps}\",\n",
    "        )\n",
    "        checklist_require(\n",
    "            cfg.apply_interval > 0,\n",
    "            f\"preflight.apply_interval_positive.{cfg.task_name}\",\n",
    "            f\"apply_interval must be > 0, got {cfg.apply_interval}\",\n",
    "        )\n",
    "        checklist_require(\n",
    "            cfg.apply_interval <= cfg.async_max_steps,\n",
    "            f\"preflight.apply_interval_le_async_steps.{cfg.task_name}\",\n",
    "            (\n",
    "                \"apply_interval cannot exceed async_max_steps; \"\n",
    "                f\"got apply_interval={cfg.apply_interval}, async_max_steps={cfg.async_max_steps}\"\n",
    "            ),\n",
    "        )\n",
    "\n",
    "    checklist_mark(\n",
    "        \"preflight.runtime_context\",\n",
    "        \"passed\",\n",
    "        f\"platform={'Windows' if IS_WINDOWS else 'Non-Windows'}, device={device}, mp_method={MP_SETUP.current_method}\",\n",
    "    )\n",
    "\n",
    "\n",
    "def checklist_summary() -> pd.DataFrame:\n",
    "    \"\"\"Return and print checklist status overview.\"\"\"\n",
    "    if not CHECKLIST_REGISTRY:\n",
    "        print(\"Checklist registry is empty.\")\n",
    "        return pd.DataFrame(columns=[\"time\", \"item\", \"status\", \"details\"])\n",
    "\n",
    "    df_ck = pd.DataFrame(CHECKLIST_REGISTRY)\n",
    "    counts = df_ck[\"status\"].value_counts().to_dict()\n",
    "    print(\"Checklist status counts:\", counts)\n",
    "    return df_ck\n",
    "\n",
    "\n",
    "run_preflight_checklist(EXPERIMENT_CONFIGS, DEVICE)\n",
    "print(\"Preflight checklist passed.\")\n",
    "checklist_summary().tail(10)"
   ]
  },
