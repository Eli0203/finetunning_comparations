     "text": [
      "Recovery and evaluation utilities ready.\n",
      "Runtime state file : c:\\tutoriales\\fineTunning\\persistent\\state\\runtime_state.json\n",
      "Results snapshot   : c:\\tutoriales\\fineTunning\\persistent\\state\\results_snapshot.json\n",
      "Platform           : Windows\n",
