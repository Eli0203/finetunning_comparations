   "source": [
    "---\n",
    "## Method 1 — Baseline LoRA\n",
    "\n",
    "Standard cross-entropy training on LoRA adapters. Freezes pre-trained weights; only $A, B$ gradients are updated.\n",
    "\n",
    "**Training loss**: Standard sequence classification cross-entropy (no special weighting).  \n",
    "**Result**: High accuracy; no calibration — confidence scores are uncalibrated."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "0b0a8295",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 12: BASELINE LORA - Training Function (resume-capable)\n",
    "# ============================================================\n",
    "\n",
    "\n",
    "def train_lora_baseline(cfg: LoRAExperimentConfig, device: str) -> dict:\n",
    "    method = \"LoRA Baseline\"\n",
    "    print(f\"\\n{'=' * 60}\")\n",
    "    print(f\"[{method}] Task: {cfg.task_name.upper()}\")\n",
    "    print(f\"{'=' * 60}\")\n",
    "\n",
    "    run_dir = str(Path(cfg.output_dir) / f\"lora_{cfg.task_name}\")\n",
    "    Path(run_dir).mkdir(parents=True, exist_ok=True)\n",
    "    ckpt = latest_checkpoint(run_dir) if should_resume(cfg) else None\n",
    "    mark_experiment_status(method, cfg.task_name, \"running\", run_dir, checkpoint=ckpt)\n",
    "\n",
    "    _, train_ds, eval_ds, _ = load_glue_runtime(cfg)\n",
    "    num_labels = GLUE_TASK_REGISTRY[cfg.task_name][\"num_labels\"]\n",
    "\n",
    "    base_model = AutoModelForSequenceClassification.from_pretrained(\n",
    "        cfg.model_id,\n",
    "        num_labels=num_labels,\n",
    "    )\n",
    "    engine = FineTuningEngine(\n",
    "        task_type=TaskType.SEQ_CLS,\n",
    "        model=base_model,\n",
    "        rank=cfg.rank,\n",
    "        alpha=cfg.alpha,\n",
    "        dropout=cfg.dropout,\n",
    "    )\n",
    "    model = engine.apply_lora()\n",
    "    model.to(device)\n",
    "\n",
    "    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "    total = sum(p.numel() for p in model.parameters())\n",
    "    print(f\"Trainable params: {trainable:,} / {total:,} ({100 * trainable / total:.3f}%)\")\n",
    "\n",
    "    evaluator = UnifiedEvaluator(cfg.task_name)\n",
    "    use_fp16, use_bf16 = resolve_precision_flags(device)\n",
    "    training_args = build_training_args(\n",
    "        cfg=cfg,\n",
    "        run_dir=run_dir,\n",
    "        metric_name=f\"eval_{GLUE_TASK_REGISTRY[cfg.task_name]['metric']}\",\n",
    "        greater_is_better=True,\n",
    "        use_fp16=use_fp16,\n",
    "        use_bf16=use_bf16,\n",
    "        max_steps=cfg.max_steps,\n",
    "        gradient_checkpointing=(device == \"cuda\"),\n",
    "    )\n",
    "\n",
    "    trainer = Trainer(\n",
    "        model=model,\n",
    "        args=training_args,\n",
    "        train_dataset=train_ds,\n",
    "        eval_dataset=eval_ds,\n",
    "        compute_metrics=make_compute_metrics(evaluator),\n",
    "    )\n",
    "\n",
    "    t_start = time.time()\n",
    "    try:\n",
    "        trainer.train(resume_from_checkpoint=ckpt)\n",
    "        eval_results = trainer.evaluate()\n",
    "        latency_ms = measure_inference_latency(model, eval_ds, device)\n",
    "    except Exception as exc:\n",
    "        mark_experiment_status(\n",
    "            method,\n",
    "            cfg.task_name,\n",
    "            \"failed\",\n",
    "            run_dir,\n",
    "            checkpoint=latest_checkpoint(run_dir),\n",
    "            error=str(exc),\n",
    "        )\n",
    "        raise\n",
    "\n",
    "    train_time_s = time.time() - t_start\n",
    "    best_ckpt = latest_checkpoint(run_dir)\n",
    "    result = {\n",
    "        \"method\": method,\n",
    "        \"task\": cfg.task_name.upper(),\n",
    "        \"accuracy\": eval_results.get(\"eval_accuracy\", float(\"nan\")),\n",
    "        \"f1\": eval_results.get(\"eval_f1\", float(\"nan\")),\n",
    "        \"nll\": eval_results.get(\"eval_nll\", float(\"nan\")),\n",
    "        \"ece\": eval_results.get(\"eval_ece\", float(\"nan\")),\n",
    "        \"latency_ms\": round(latency_ms, 3),\n",
    "        \"train_time_s\": round(train_time_s, 1),\n",
    "        \"trainable_params\": trainable,\n",
    "        \"output_dir\": run_dir,\n",
    "        \"checkpoint\": best_ckpt,\n",
    "    }\n",
    "    mark_experiment_status(\n",
    "        method,\n",
    "        cfg.task_name,\n",
    "        \"completed\",\n",
    "        run_dir,\n",
    "        checkpoint=best_ckpt,\n",
    "        metrics=result,\n",
    "    )\n",
    "    cleanup_memory(f\"{method}-{cfg.task_name}\")\n",
    "    print(f\"Completed: {result}\")\n",
    "    return result"
   ]
  },
