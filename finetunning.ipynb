    "# ============================================================\n",
    "# CELL 8: FLEXIBLE GLUE RUNTIME LOADER\n",
    "# Delegates schema/tokenization logic to src/finetuner/data_loader.py\n",
    "# so the notebook and main.py share the same task strategies.\n",
    "# ============================================================\n",
    "\n",
    "def load_glue_runtime(cfg: LoRAExperimentConfig):\n",
    "    \"\"\"Return the shared source loader plus tokenized train/eval splits.\"\"\"\n",
    "    loader = GLUEDataLoader(\n",
    "        model_id=cfg.model_id,\n",
    "        task_name=cfg.task_name,\n",
    "        max_length=cfg.max_seq_length,\n",
    "    )\n",
    "    train_ds, eval_ds, tokenizer = loader.get_datasets(train_split=\"train\")\n",
    "    return loader, train_ds, eval_ds, tokenizer\n",
    "\n",
    "\n",
    "print(\"✅  GLUE runtime helpers ready (src-integrated).\")\n",
    "print(f\"   Supported tasks: {GLUEDataLoader.supported_tasks()}\")"
   ]
  },
